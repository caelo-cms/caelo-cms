# Copy to .env and adjust for your local dev environment.
# .env is gitignored — never commit real secrets.

# PostgreSQL (docker-compose)
POSTGRES_USER=caelo
POSTGRES_PASSWORD=caelo_dev
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Connection string used by apps + tests
DATABASE_URL=postgres://caelo:caelo_dev@localhost:5432/postgres
