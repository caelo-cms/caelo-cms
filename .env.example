# Copy to .env and adjust for your local dev environment.
# .env is gitignored — never commit real secrets.

# PostgreSQL superuser (docker-compose)
POSTGRES_USER=caelo
POSTGRES_PASSWORD=caelo_dev
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Application roles created by packages/migrations/src/bootstrap.sh on first boot.
ADMIN_ROLE_PASSWORD=caelo_admin_dev
PUBLIC_ROLE_PASSWORD=caelo_public_dev

# Application connection URLs.
# admin_role connects to cms_admin (authoring) and to cms_public (schema owner for DDL / migrations only).
# public_role connects to cms_public (plugin-data API gateway path).
ADMIN_DATABASE_URL=postgres://admin_role:caelo_admin_dev@localhost:5432/cms_admin
PUBLIC_ADMIN_DATABASE_URL=postgres://admin_role:caelo_admin_dev@localhost:5432/cms_public
PUBLIC_DATABASE_URL=postgres://public_role:caelo_public_dev@localhost:5432/cms_public
