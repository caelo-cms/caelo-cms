{
  "name": "@caelo-cms/mcp-server",
  "version": "0.5.2",
  "private": false,
  "license": "MPL-2.0",
  "description": "MCP server exposing the Caelo CMS chat-runner as a `caelo_chat` tool. Lets Claude Code (or any MCP-aware client) drive a Caelo install from outside the browser.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caelo-cms/caelo-cms.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/caelo-cms/caelo-cms#readme",
  "bugs": "https://github.com/caelo-cms/caelo-cms/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "caelo-mcp-server": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "build": "tsc -b --force",
    "prepublishOnly": "tsc -b --force"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
