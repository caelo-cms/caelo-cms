{
  "$description": "Saturated colors, sans-serif everything, large radii. For consumer brands that want energy.",
  "color": {
    "background": { "$type": "color", "$value": "#ffffff" },
    "foreground": { "$type": "color", "$value": "#0f172a" },
    "primary": { "$type": "color", "$value": "#7c3aed" },
    "primary-foreground": { "$type": "color", "$value": "#ffffff" },
    "secondary": { "$type": "color", "$value": "#fbbf24" },
    "secondary-foreground": { "$type": "color", "$value": "#0f172a" },
    "accent": { "$type": "color", "$value": "#ec4899" },
    "accent-foreground": { "$type": "color", "$value": "#ffffff" },
    "muted": { "$type": "color", "$value": "#f1f5f9" },
    "muted-foreground": { "$type": "color", "$value": "#475569" },
    "card": { "$type": "color", "$value": "#ffffff" },
    "card-foreground": { "$type": "color", "$value": "#0f172a" },
    "border": { "$type": "color", "$value": "#e2e8f0" },
    "ring": { "$type": "color", "$value": "#7c3aed" },
    "destructive": { "$type": "color", "$value": "#ef4444" },
    "destructive-foreground": { "$type": "color", "$value": "#ffffff" }
  },
  "typography": {
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Inter', system-ui, sans-serif",
        "fontSize": "1rem",
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Inter', system-ui, sans-serif",
        "fontSize": "2.5rem",
        "fontWeight": 800,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      }
    },
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Inter', system-ui, sans-serif",
        "fontSize": "4rem",
        "fontWeight": 900,
        "lineHeight": 1,
        "letterSpacing": "-0.03em"
      }
    }
  },
  "spacing": {
    "xs": { "$type": "dimension", "$value": "0.25rem" },
    "sm": { "$type": "dimension", "$value": "0.5rem" },
    "md": { "$type": "dimension", "$value": "1rem" },
    "lg": { "$type": "dimension", "$value": "1.5rem" },
    "xl": { "$type": "dimension", "$value": "2rem" },
    "2xl": { "$type": "dimension", "$value": "3rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "0.5rem" },
    "md": { "$type": "dimension", "$value": "1rem" },
    "lg": { "$type": "dimension", "$value": "1.5rem" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(124, 58, 237, 0.15)",
        "offsetX": "0",
        "offsetY": "2px",
        "blur": "8px"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(124, 58, 237, 0.2)",
        "offsetX": "0",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "-4px"
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(236, 72, 153, 0.25)",
        "offsetX": "0",
        "offsetY": "16px",
        "blur": "40px",
        "spread": "-8px"
      }
    }
  }
}
