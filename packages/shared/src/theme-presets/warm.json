{
  "$description": "Earthy palette, serif headings, generous spacing. For lifestyle / hospitality / wellness brands.",
  "color": {
    "background": { "$type": "color", "$value": "#fdf6e3" },
    "foreground": { "$type": "color", "$value": "#3c2e26" },
    "primary": { "$type": "color", "$value": "#8b4513" },
    "primary-foreground": { "$type": "color", "$value": "#fff8e7" },
    "secondary": { "$type": "color", "$value": "#e8d5b7" },
    "secondary-foreground": { "$type": "color", "$value": "#3c2e26" },
    "accent": { "$type": "color", "$value": "#c4471c" },
    "accent-foreground": { "$type": "color", "$value": "#fff8e7" },
    "muted": { "$type": "color", "$value": "#f0e4c8" },
    "muted-foreground": { "$type": "color", "$value": "#6b5544" },
    "card": { "$type": "color", "$value": "#fff8e7" },
    "card-foreground": { "$type": "color", "$value": "#3c2e26" },
    "border": { "$type": "color", "$value": "#d4b896" },
    "ring": { "$type": "color", "$value": "#8b4513" },
    "destructive": { "$type": "color", "$value": "#a02d2d" },
    "destructive-foreground": { "$type": "color", "$value": "#fff8e7" }
  },
  "typography": {
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Lora', Georgia, serif",
        "fontSize": "1.0625rem",
        "fontWeight": 400,
        "lineHeight": 1.7
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Playfair Display', 'Lora', Georgia, serif",
        "fontSize": "2.25rem",
        "fontWeight": 700,
        "lineHeight": 1.2
      }
    }
  },
  "spacing": {
    "xs": { "$type": "dimension", "$value": "0.375rem" },
    "sm": { "$type": "dimension", "$value": "0.75rem" },
    "md": { "$type": "dimension", "$value": "1.5rem" },
    "lg": { "$type": "dimension", "$value": "2.25rem" },
    "xl": { "$type": "dimension", "$value": "3rem" },
    "2xl": { "$type": "dimension", "$value": "4.5rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "0.375rem" },
    "md": { "$type": "dimension", "$value": "0.75rem" },
    "lg": { "$type": "dimension", "$value": "1rem" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(60, 46, 38, 0.08)",
        "offsetX": "0",
        "offsetY": "2px",
        "blur": "4px"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(60, 46, 38, 0.12)",
        "offsetX": "0",
        "offsetY": "6px",
        "blur": "12px",
        "spread": "-2px"
      }
    }
  }
}
