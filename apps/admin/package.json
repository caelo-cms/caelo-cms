    "@caelo-cms/plugin-host": "workspace:*",
    "@caelo-cms/plugin-newsletter": "workspace:*",
    "@caelo-cms/plugin-ratings": "workspace:*",
    "@caelo-cms/plugin-sandbox": "workspace:*",
    "@caelo-cms/plugin-sdk": "workspace:*",
    "@caelo-cms/plugin-translation": "workspace:*",
    "@caelo-cms/query-api": "workspace:*",
    "@caelo-cms/redeploy-orchestrator": "workspace:*",
    "@caelo-cms/shared": "workspace:*",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "file-type": "^19",
    "lucide-svelte": "^1.0.1",
