{
  "name": "@caelo/admin",
  "version": "0.0.0",
  "private": true,
  "license": "MPL-2.0",
  "type": "module",
  "scripts": {
    "sync": "svelte-kit sync",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig tsconfig.json && tsc --noEmit",
    "dev": "svelte-kit sync && bun --bun vite dev",
    "build": "svelte-kit sync && bun --bun vite build",
    "preview": "bun --bun vite preview",
    "seed:dev": "bun --env-file=../../.env run scripts/seed-dev-owner.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@caelo/admin-core": "workspace:*",
    "@caelo/query-api": "workspace:*",
    "@caelo/shared": "workspace:*",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "lucide-svelte": "^1.0.1",
    "mode-watcher": "^1.1.0",
    "svelte-dnd-action": "^0.9.69",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^2.5.5",
    "tailwind-variants": "^1.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "1.59.1",
    "@sveltejs/kit": "2.58.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "svelte": "5.55.5",
    "svelte-adapter-bun": "1.0.1",
    "svelte-check": "4.4.6",
    "tailwindcss": "^4.2.4",
    "vite": "8.0.10"
  }
}
