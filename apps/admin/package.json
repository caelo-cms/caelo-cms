{
  "name": "@caelo-cms/admin",
  "version": "0.10.22",
  "private": true,
  "license": "MPL-2.0",
  "type": "module",
  "scripts": {
    "sync": "svelte-kit sync",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig tsconfig.json && tsc --noEmit",
    "dev": "svelte-kit sync && bun --bun vite dev",
    "build": "svelte-kit sync && bun --bun vite build",
    "preview": "bun --bun vite preview",
    "seed:dev": "bun --env-file=../../.env run scripts/seed-dev-owner.ts",
    "e2e": "playwright test",
    "e2e-livedit": "svelte-kit sync && bun --bun vite build && playwright test --config playwright.livedit.config.ts",
    "e2e-livedit:headed": "svelte-kit sync && bun --bun vite build && playwright test --config playwright.livedit.config.ts --headed",
    "e2e-livedit:debug": "svelte-kit sync && bun --bun vite build && playwright test --config playwright.livedit.config.ts --headed --debug --workers=1"
  },
  "dependencies": {
    "@caelo-cms/admin-core": "workspace:*",
    "@caelo-cms/plugin-auth": "workspace:*",
    "@caelo-cms/plugin-comments": "workspace:*",
    "@caelo-cms/plugin-forms": "workspace:*",
    "@caelo-cms/plugin-host": "workspace:*",
    "@caelo-cms/plugin-newsletter": "workspace:*",
    "@caelo-cms/plugin-ratings": "workspace:*",
    "@caelo-cms/plugin-sandbox": "workspace:*",
    "@caelo-cms/plugin-sdk": "workspace:*",
    "@caelo-cms/plugin-translation": "workspace:*",
    "@caelo-cms/query-api": "workspace:*",
    "@caelo-cms/redeploy-orchestrator": "workspace:*",
    "@caelo-cms/shared": "workspace:*",
    "@google-cloud/storage": "^7.21.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "colorjs.io": "^0.6.1",
    "dompurify": "^3",
    "file-type": "^22",
    "html2canvas-pro": "2.2.4",
    "lucide-svelte": "^1.0.1",
    "marked": "^14",
    "mode-watcher": "^1.1.0",
    "svelte-dnd-action": "^0.9.70",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^2.5.5",
    "tailwind-variants": "^1.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "1.61.1",
    "@sveltejs/kit": "2.69.2",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "svelte": "5.56.4",
    "svelte-adapter-bun": "1.0.1",
    "svelte-check": "4.7.2",
    "tailwindcss": "^4.3.2",
    "vite": "8.1.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4",
    "@rollup/rollup-darwin-x64": "^4",
    "@rollup/rollup-linux-arm64-gnu": "^4",
    "@rollup/rollup-linux-arm64-musl": "^4",
    "@rollup/rollup-linux-x64-gnu": "^4",
    "@rollup/rollup-linux-x64-musl": "^4"
  }
}
