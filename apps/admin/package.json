    "@playwright/test": "1.59.1",
    "@sveltejs/kit": "2.58.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "svelte": "5.55.5",
    "svelte-adapter-bun": "1.0.1",
    "svelte-check": "4.4.6",
    "tailwindcss": "^4.2.4",
    "vite": "8.0.10"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4",
