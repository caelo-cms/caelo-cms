.claude/

# Local AI workflow orchestrator — not part of the CMS source tree.
claude-workflow/
# Orchestrator's per-run plan file. Was briefly committed under #47
# (commit 80901c1) but every workflow run rewrites it, so each run
# produced a 700-line "diff" that polluted PRs and forced manual
# stashing between runs. Untracked + ignored; the file stays on
# disk for the active run.
.workflow-plan.md

# Playwright MCP server scratch directory (page snapshots, console
# logs, screenshots from `mcp__playwright__*` calls during dev /
# step 13 browser walks). Local debug state; never source.
.playwright-mcp/

# Phase 6 static-gen output (per-target dist trees)
apps/admin/output/
output/dev/
output/staging/
output/production/

# Per-install runtime state (dev KEK auto-generated by hooks.server.ts on
# first `bun run dev`; pending-token holds the Owner setup link payload).
.caelo/

# P12 review pass — Tier-1 plugin signing artifacts.
# `.caelo-dev-key` holds a per-developer Ed25519 keypair generated by
# scripts/sign-tier1-manifest.ts. Production releases sign with the
# Caelo release key embedded in plugin-sandbox/manifest.ts.
.caelo-dev-key
packages/plugins/*/manifest.sig
packages/plugins/*/manifest.json
