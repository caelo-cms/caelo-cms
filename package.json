{
  "name": "caelo-cms",
  "version": "0.10.22",
  "private": true,
  "description": "AI-first, open-source CMS (MPL 2.0).",
  "license": "MPL-2.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "typecheck": "tsc -b && bun run --filter=@caelo-cms/admin typecheck",
    "typecheck:clean": "tsc -b --clean",
    "test": "bun test --isolate",
    "coverage": "bun test --coverage",
    "coverage:check": "bun run scripts/coverage-check.ts",
    "lint": "biome check . && bun run --filter=@caelo-cms/admin-core lint:audit && bun run --filter=@caelo-cms/admin-core lint:spdx",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow 'MPL-2.0;Apache-2.0;MIT;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;CC0-1.0;Unlicense;Python-2.0;BlueOak-1.0.0' --excludePackages 'caelo-cms'",
    "db:generate": "bun run --filter=@caelo-cms/migrations generate:admin && bun run --filter=@caelo-cms/migrations generate:public",
    "db:migrate": "bun run packages/migrations/src/migrate.ts admin && bun run packages/migrations/src/migrate.ts public",
    "plugins:sign": "bun run apps/admin/scripts/sign-tier1-manifest.ts",
    "rulesets:apply": "bun run scripts/apply-rulesets.ts",
    "rulesets:check": "bun run scripts/apply-rulesets.ts --check",
    "security:enable": "bun run scripts/enable-security-features.ts",
    "security:check": "bun run scripts/enable-security-features.ts --check",
    "knip": "knip",
    "knip:strict": "knip --reporter github-actions",
    "knip:fix": "knip --fix",
    "circular": "madge --circular apps packages",
    "e2e-livedit": "bun run --filter '@caelo-cms/admin' e2e-livedit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/mcp": "0.0.78",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "4.0.9",
    "js-yaml": "4.2.0",
    "knip": "6.25.0",
    "license-checker-rseidelsohn": "5.0.1",
    "madge": "8.0.0",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
