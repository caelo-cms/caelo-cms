{
  "name": "caelo-cms",
  "version": "0.0.0",
  "private": true,
  "description": "AI-first, open-source CMS (MPL 2.0).",
  "license": "MPL-2.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter='*' typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "latest",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
